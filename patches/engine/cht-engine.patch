+/* U4 繁中化:把一個 CJK glyph(dim×dim alpha)blit 到文字區 cell(col,line)。
+ * CJK 為全形,佔 2 欄 × 2 列(16×16 px),白字黑底。 */
+static void cjkBlit(uint32_t cp, int col, int line) {
+    const uint8_t* g = chtGlyph(cp);
+    int dim = chtGlyphDim();
+    Image* screen = xu4.screenImage;
+    int px = (TEXT_AREA_X + col) * CHAR_WIDTH;
+    int py = (TEXT_AREA_Y + line) * CHAR_HEIGHT;
+    if (! g) {
+        screen->fillRect(px, py, dim, dim, 60, 60, 60);   // 缺字:灰框
+        return;
+    }
+    for (int y = 0; y < dim; ++y)
+        for (int x = 0; x < dim; ++x) {
+            int a = g[y * dim + x];   // 灰階 alpha:白字混黑底(二值 atlas 亦相容)
+            screen->putPixel(px + x, py + y, a, a, a, 255);
+        }
+}
+
+/* U4 繁中化:把已翻譯的 UTF-8 中文字串渲染到文字區(CJK-aware,行距 2)。 */
+static void screenMessageCJK(const char* s) {
+    const int colCount = TEXT_AREA_W;
+    const unsigned char* p = (const unsigned char*) s;
+    if (c->line >= TEXT_AREA_H) { c->line = TEXT_AREA_H - 1; screenScrollMessageArea(); }
+    while (*p) {
+        unsigned char b = *p;
+        if (b == '\n') {
+            c->col = 0; c->line += 2;
+            while (c->line >= TEXT_AREA_H) { c->line--; screenScrollMessageArea(); }
+            ++p; continue;
+        }
+        uint32_t cp; int n;
+        if (b < 0x80)            { cp = b;        n = 1; }
+        else if ((b >> 5) == 0x6){ cp = b & 0x1F; n = 2; }
+        else if ((b >> 4) == 0xE){ cp = b & 0x0F; n = 3; }
+        else if ((b >> 3) == 0x1E){cp = b & 0x07; n = 4; }
+        else { ++p; continue; }
+        for (int k = 1; k < n; ++k) {
+            if ((p[k] & 0xC0) != 0x80) { n = k; break; }
+            cp = (cp << 6) | (p[k] & 0x3F);
+        }
+        p += n;
+        if (cp < 0x80) {                          // 夾雜 ASCII
+            if (c->col >= colCount) { c->col = 0; c->line += 2;
+                while (c->line >= TEXT_AREA_H) { c->line--; screenScrollMessageArea(); } }
+            screenShowChar((int) cp, TEXT_AREA_X + c->col, TEXT_AREA_Y + c->line);
+            c->col++;
+        } else {                                  // CJK 全形,佔 2 欄
+            if (c->col + 2 > colCount) { c->col = 0; c->line += 2;
+                while (c->line >= TEXT_AREA_H) { c->line--; screenScrollMessageArea(); } }
+            cjkBlit(cp, c->col, c->line);
+            c->col += 2;
+        }
+    }
+    screenSetCursorPos(TEXT_AREA_X + c->col, TEXT_AREA_Y + c->line);
+}
